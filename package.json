{
  "name": "dom-inspect",
  "version": "0.1.0",
  "description": "Point at any DOM element in the browser and get the source file and line number",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "vite-plugin",
    "react",
    "source",
    "devtools",
    "babel"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/types": "^7.24.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
